rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Safe admin check — reads from users collection
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == "admin";
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // 1. PRODUCTS
    match /products/{product} {
      allow read: if true;
      allow update: if request.auth != null;
      allow create, delete: if isAdmin();
    }

    // 2. ORDERS
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow update: if request.auth != null && (
        isAdmin() ||
        (resource.data.userId == request.auth.uid &&
         resource.data.status == "Pending" &&
         request.resource.data.status == "Cancelled")
      );
      allow delete: if isAdmin();
    }

    // 3. ANNOUNCEMENTS — general broadcasts only (no personal data here)
    //    All authenticated users can read. Only admins can write.
    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // 3b. NOTIFICATIONS — personal order/payment notifications per user
    //     Only the owning user (or admin) can read. Only admins can write.
    match /notifications/{userId}/items/{notifId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // 3c. NOTIFICATION LOG — admin-only log of sent pickup notifications
    match /notificationLog/{logId} {
      allow read, write: if isAdmin();
    }

    // 4. COUPONS
    match /coupons/{couponId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // 5. SETTINGS
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 6. USERS
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow read: if request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role','') == "admin";
      allow write: if isOwner(userId);
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role','') == "admin";
    }

    // 7. REVIEWS
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // 8. FAVORITES — users manage their own favorites subcollection
    match /favorites/{userId}/items/{itemId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 9. CHATS
    match /chats/{sessionId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null &&
        sessionId == ("chat_" + request.auth.uid);
      allow create: if request.auth != null &&
        sessionId == ("chat_" + request.auth.uid) &&
        request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
        sessionId == ("chat_" + request.auth.uid);
    }

    match /chats/{sessionId}/messages/{msgId} {
      allow read, write: if isAdmin();
      allow read, create: if request.auth != null &&
        sessionId == ("chat_" + request.auth.uid);
    }
  }
}
